{
  "name": "netglobe",
  "version": "1.0.0",
  "description": "See where your computer connects on a live world map",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"NETGLOBE_DEV=1 tsx watch src/server/index.ts\" \"sleep 3 && vite\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "fastify": "^5.0.0",
    "ipaddr.js": "^2.2.0",
    "maxmind": "^4.3.0",
    "open": "^10.1.0",
    "ws": "^8.18.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.0",
    "@types/ws": "^8.5.0",
    "concurrently": "^9.0.0",
    "leaflet": "^1.9.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
